#!/usr/bin/env bash

set -euo pipefail

# ─── Settings ────────────────────────────────────────────────
PROXY_HOST="127.0.0.1"
PROXY_PORT="10302"
PROFILE_DIR="${HOME}/.config/chromium_group/chromium_pay"
CACHE_DIR="${HOME}/.cache/chromium_group/chromium_pay"
TIMEZONE="Asia/Singapore"
LANG_TAG="en-US"
PROXY_URL="socks5://${PROXY_HOST}:${PROXY_PORT}"
# ──────────────────────────────────────────────────────────────
notify_fail() {
    local msg="$1"
    echo "!! ${msg}" >&2
    if command -v notify-send &>/dev/null; then
        notify-send -u critical -a "Chromium Pay" "Failed to start pay profile" "${msg}"
    fi
}

echo "==> check proxy: ${PROXY_HOST}:${PROXY_PORT}..."
if ! curl -sf --max-time 8 -x "socks5h://${PROXY_HOST}:${PROXY_PORT}" \
        https://api.ipify.org > /tmp/.proxy_pay_ip 2>/dev/null; then
    notify_fail "Proxy ${PROXY_HOST}:${PROXY_PORT} unreachable."
    exit 1
fi

if ! grep -qE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' /tmp/.proxy_pay_ip; then
    notify_fail "Proxy returned unexpected response: $(cat /tmp/.proxy_pay_ip)"
    exit 1
fi
echo "==> check result: $(cat /tmp/.proxy_pay_ip)"

mkdir -p "$PROFILE_DIR" "$CACHE_DIR"

# ──────────────────────────────────────────────────────────────
CHROMIUM_FLAGS=(
    --user-data-dir="${PROFILE_DIR}"
    --disk-cache-dir="${CACHE_DIR}"
    --proxy-server="${PROXY_URL}"
    --proxy-bypass-list="localhost,127.0.0.1,[::1]"
    # disable webrtc
    --force-webrtc-ip-handling-policy="disable_non_proxied_udp"
    # DNS leak kill-switch
    --host-resolver-rules="MAP * ~NOTFOUND , EXCLUDE localhost , EXCLUDE 127.0.0.1 , EXCLUDE [::1]"
    --lang="${LANG_TAG}"
    --accept-lang="en-US,en;q=0.9"
    --class="chromium_pay"
    # disable main profile sync
    --disable-sync
    --test-type
    --disable-background-networking
    --no-default-browser-check
    --no-first-run
    --restore-last-session
)

# ──────────────────────────────────────────────────────────────
export TZ="${TIMEZONE}"
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

exec /usr/bin/chromium "${CHROMIUM_FLAGS[@]}" "$@"
